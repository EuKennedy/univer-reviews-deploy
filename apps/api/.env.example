# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/univerreviews_development

# Redis / Sidekiq
REDIS_URL=redis://localhost:6379/0
SIDEKIQ_CONCURRENCY=10

# App
RAILS_ENV=development
SECRET_KEY_BASE=generate_with_rails_secret
JWT_SECRET=generate_min_64_chars_random_string
PORT=3000
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2

# CORS / Frontend
FRONTEND_URL=http://localhost:3001
ADMIN_URL=https://app.univerreviews.com

# Email
RESEND_API_KEY=re_xxxx
FROM_EMAIL=reviews@univerreviews.com

# AI
ANTHROPIC_API_KEY=sk-ant-xxxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxx

# Storage (MinIO / S3)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_S3_BUCKET=univerreviews
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_FORCE_PATH_STYLE=true

# Monitoring
SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/XXXX
SENTRY_TRACES_SAMPLE_RATE=0.1
