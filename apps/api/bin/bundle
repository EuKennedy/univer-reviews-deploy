#!/usr/bin/env ruby
# frozen_string_literal: true

#
# This file was generated by Bundler.
#
# The application's dependencies are maintained with Bundler. When you need
# to update dependencies, run `bundle update`.
#
require "rubygems"

m = Module.new do
  module_function

  def invoked_as_script?
    File.expand_path($0) == File.expand_path(__FILE__)
  end

  def env_var_version
    ENV.fetch("BUNDLER_VERSION", nil)
  end

  def cli_arg_version
    return unless invoked_as_script? # don't want to hijack Bundler's versioning

    bundler_version = nil
    update_index = nil
    ARGV.each_with_index do |a, i|
      if update_index && update_index.succ == i && a =~ Gem::Version::ANCHORED_VERSION_PATTERN
        bundler_version = a
      end
      next unless a =~ /\A--bundler\z/

      bundler_version = a
      update_index = i
    end
    bundler_version
  end

  def gemfile
    gemfile = ENV.fetch("BUNDLE_GEMFILE", nil)
    return gemfile if gemfile

    File.expand_path("../../Gemfile", __FILE__)
  end

  def lockfile
    lockfile = gemfile + ".lock"
    return lockfile if File.exist?(lockfile)

    nil
  end

  def lockfile_version
    return unless (lockfile = self.lockfile)

    lockfile_contents = File.read(lockfile)
    return unless (match = lockfile_contents.match(/\nBUNDLED WITH\n\s*(#{Gem::Version::VERSION_PATTERN})\n/))

    match[1]
  end

  def bundler_requirement
    @bundler_requirement ||= \
      env_var_version ||
      cli_arg_version ||
      lockfile_version
  end

  def load_bundler!
    $LOAD_PATH.unshift(File.expand_path("../../", __FILE__))
    require "bundler/version"
    return if Gem::Version.new(Bundler::VERSION).send(:>=, Gem::Version.new(bundler_requirement))

    spec = Gem::Specification.find_by_name("bundler", bundler_requirement)
    gem_bin = File.join(spec.gem_dir, "exe", "bundler")
    exec gem_bin, *ARGV
  rescue Gem::GemNotFoundException
    nil
  end

  def invoke_bundler!
    if bundler_requirement
      load_bundler!
    end

    load Gem.bin_path("bundler", "bundler")
  end
end

m.invoke_bundler!
