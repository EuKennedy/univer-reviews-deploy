# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=univerreviews
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=univerreviews_production

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ─── MinIO (Object Storage) ───────────────────────────────────────────────────
MINIO_ROOT_USER=univerreviews
MINIO_ROOT_PASSWORD=change_me_minio_password

# ─── Rails ────────────────────────────────────────────────────────────────────
SECRET_KEY_BASE=generate_with_rails_secret

# ─── Next.js / Auth ───────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@univerreviews.com

# ─── Billing ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── URLs ─────────────────────────────────────────────────────────────────────
API_URL=https://api.univerreviews.com
FRONTEND_URL=https://dash.univerreviews.com
